# PostgreSQL connection (compose default + local host port)
DATABASE_URL=postgresql://feedback:feedback@localhost:5432/feedback

# App port reference (Next: use `npm run dev` or `next dev -p $PORT`; default 3000)
PORT=3000

# AI
OPENAI_API_KEY=
AI_PROVIDER=mock
OPENAI_MODEL=gpt-4o-mini

# Client-facing API origin (same app in single Next deployment)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_POST_MAX=10

# Optional: when set, require x-api-key on /api/*
API_KEY=

# Logging
LOG_LEVEL=info
LOG_PROVIDER=pino
